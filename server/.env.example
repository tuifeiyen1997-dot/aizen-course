# ───── 伺服器 ─────
PORT=8080
# 後端對外網址（綠界 server-to-server 回呼會打這個，必須是公開可連的 https）
BASE_URL=https://api.你的網域.com
# 允許的前端來源（CORS）。多個用逗號分隔，例如 Webflow 測試網域 + 正式網域
ALLOWED_ORIGIN=https://你的站.webflow.io,https://www.ai-zen.co
# 付款完成後，綠界把用戶導回的頁面（你的感謝頁）
THANKYOU_URL=https://你的站.webflow.io/thank-you

# ───── 資料庫 (PostgreSQL) ─────
DATABASE_URL=postgres://user:password@localhost:5432/aizen

# ───── 綠界 ECPay ─────
# 以下是綠界官方「測試環境」公開測試帳號，可直接用來串接測試。
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# 上正式環境時改成你的正式商店資料，並把 API_URL 換成正式網址：
# ECPAY_MERCHANT_ID=你的正式MerchantID
# ECPAY_HASH_KEY=你的正式HashKey
# ECPAY_HASH_IV=你的正式HashIV
# ECPAY_API_URL=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
